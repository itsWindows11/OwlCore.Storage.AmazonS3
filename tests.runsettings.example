<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <SUPABASE_S3_ENDPOINT>...</SUPABASE_S3_ENDPOINT>
      <SUPABASE_S3_ACCESS_KEY>...</SUPABASE_S3_ACCESS_KEY>
      <SUPABASE_S3_SECRET_KEY>...</SUPABASE_S3_SECRET_KEY>
      <SUPABASE_S3_BUCKET>...</SUPABASE_S3_BUCKET>
      <SUPABASE_S3_REGION>...</SUPABASE_S3_REGION>
      <SUPABASE_S3_FORCE_PATH_STYLE>true/false</SUPABASE_S3_FORCE_PATH_STYLE>
      <SUPABASE_S3_SKIP_LARGE_COPY_TESTS>true/false</SUPABASE_S3_SKIP_LARGE_COPY_TESTS>
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
